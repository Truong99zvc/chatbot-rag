# HuggingFace API Token (required for LLM)
# Get your free token at: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# LLM model via HF Inference API (optional — default shown)
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
LLM_TEMPERATURE=0.2

# Embedding model — via HF Inference API (no local GPU/CPU crash issues)
# Used for document retrieval and queries
EMBEDDING_MODEL=intfloat/multilingual-e5-large

# FAISS index location (optional — default shown)
FAISS_INDEX_DIR=vectorstores/faiss/current_index

# Debug mode (optional)
DEBUG=false
